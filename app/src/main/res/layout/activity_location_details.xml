<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FDF8F2"
    android:fitsSystemWindows="true"
    tools:context=".views.LocationDetailsActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_action_bar">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/ivDetailLocationImage"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:scaleType="centerCrop"
                android:src="@drawable/image_not_loaded" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="280dp"
                app:cardBackgroundColor="#FDF8F2"
                app:cardCornerRadius="30dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/tvDetailLocationName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#4A3B32"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        tools:text="Biserica Fortificată Biertan" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvDetailLocationCity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#6D6158"
                            android:textSize="15sp"
                            android:drawablePadding="6dp"

                            app:drawableTint="#B18F5B"
                            tools:text="Biertan, Sibiu" />

                        <Space
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tvDetailLocationCategory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/google_white_bg"
                            android:backgroundTint="#E2E5D9"
                            android:paddingStart="12dp"
                            android:paddingTop="6dp"
                            android:paddingEnd="12dp"
                            android:paddingBottom="6dp"
                            android:textColor="#5D6A4E"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            tools:text="Mănăstiri &amp; Biserici" />
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        app:cardBackgroundColor="#F5EBE1"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:baselineAligned="false">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="horizontal">
                                <TextView
                                    android:id="@+id/tvDetailViews"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="#7A4B3A"
                                    android:textStyle="bold"
                                    android:drawablePadding="6dp"
                                    app:drawableStartCompat="@drawable/ic_views"
                                    app:drawableTint="#7A4B3A"
                                    tools:text="28.5k vizualizări" />
                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:background="#D8C8B8" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="horizontal">
                                <TextView
                                    android:id="@+id/tvDetailFavoritesCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="#7A4B3A"
                                    android:textStyle="bold"
                                    android:drawablePadding="6dp"
                                    app:drawableStartCompat="@drawable/ic_favorite"
                                    app:drawableTint="#7A4B3A"
                                    tools:text="7.1k favorite" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvDetailLocationDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:textColor="#333333"
                        android:textSize="16sp"
                        android:lineSpacingExtra="4dp"
                        tools:text="Complex medieval UNESCO celebru pentru ușa sacristiei..." />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:layout_marginBottom="24dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <fragment
                                android:id="@+id/mapDetail"
                                android:name="com.google.android.gms.maps.SupportMapFragment"
                                android:layout_width="match_parent"
                                android:layout_height="150dp" />

                            <Button
                                android:id="@+id/btnOpenFullMap"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:backgroundTint="@android:color/white"
                                android:text="VEZI LOCAȚIA PE HARTĂ"
                                android:textColor="#B18F5B"
                                android:textStyle="bold"
                                app:cornerRadius="0dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </RelativeLayout>
    </androidx.core.widget.NestedScrollView>

    <ImageButton
        android:id="@+id/btnHome"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="20dp"

        android:background="@drawable/bg_circle_translucent"
        android:src="@drawable/ic_back"
        app:tint="@android:color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:elevation="4dp"
        android:contentDescription="Înapoi" />

    <ImageButton
        android:id="@+id/btnFavoriteToggle"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="20dp"

        android:background="@drawable/bg_circle_translucent"

        android:src="@drawable/ic_favorite"

        app:tint="@android:color/white"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"

        android:elevation="4dp"
        android:contentDescription="Adaugă la favorite" />
    <LinearLayout
    android:id="@+id/bottom_action_bar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FDF8F2"
    android:elevation="16dp"
    android:padding="16dp"
    app:layout_constraintBottom_toBottomOf="parent">

    <Button
        android:id="@+id/btnAddToTrip"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="#B18F5B"
        android:text="Adaugă în Plan"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="28dp" />
</LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>