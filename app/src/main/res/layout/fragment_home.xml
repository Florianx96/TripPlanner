<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:scaleType="centerCrop"
            android:src="@drawable/header_background" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="48dp"
            android:paddingBottom="16dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_welcome_message"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome UserName"
                        android:textSize="16sp"
                        android:textColor="#000" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Explore Romania"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#000000"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/btn_settings"
                    android:layout_width="50dp"
                    android:layout_height="55dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_luffy"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"/>
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_search_transparent"
                    android:hint="Caută destinații..."
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:maxLines="1"
                    android:inputType="text"/>

                <ImageButton
                    android:id="@+id/btn_filter"
                    android:layout_width="50dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_search_transparent"
                    android:src="@android:drawable/ic_menu_sort_by_size"/>
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="10dp"
                android:paddingEnd="16dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chip_turism"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏰 Locații Turistice"
                        android:textColor="@android:color/white"
                        android:background="@drawable/bg_chip_selected"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/chip_food"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🍽️ Restaurante &amp; Cafenele"
                        android:textColor="#555555"
                        android:background="@drawable/bg_chip_unselected"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/chip_relax"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎉 Relaxare &amp; Distracție"
                        android:textColor="#555555"
                        android:background="@drawable/bg_chip_unselected"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </HorizontalScrollView>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tv_carousel_title_main"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="🔥 Recomandate"
                    android:textColor="#333333"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btn_toggle_gps"
                    android:layout_width="30dp"
                    android:layout_height="35dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="12dp"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_location_on"
                    app:tint="#888888" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false">

                <ProgressBar
                    android:id="@+id/progress_gps"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_centerInParent="true"
                    android:visibility="gone"
                    android:indeterminateTint="#4A90E2"
                    android:elevation="10dp"/>

                <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewPager_recomandate"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:clipToPadding="false" />

                <ImageButton
                    android:id="@+id/btn_prev_carousel"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_circle_translucent"
                    android:src="@drawable/ic_backward"
                    app:tint="#FFFFFF"
                    android:elevation="8dp"/>

                <ImageButton
                    android:id="@+id/btn_next_carousel"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_circle_translucent"
                    android:src="@drawable/ic_forwoard"
                    app:tint="#FFFFFF"
                    android:elevation="8dp"/>

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/tabLayout_dots"
                    android:layout_width="match_parent"
                    android:layout_height="18dp"
                    android:layout_alignBottom="@id/viewPager_recomandate"
                    android:layout_marginBottom="6dp"
                    android:background="@android:color/transparent"
                    app:tabBackground="@drawable/dot_selector"
                    app:tabGravity="center"
                    app:tabIndicatorHeight="0dp"
                    app:tabRippleColor="@null"
                    app:tabPaddingStart="0dp"
                    app:tabPaddingEnd="0dp"
                    app:tabMinWidth="16dp"
                    app:tabMaxWidth="16dp" />
            </RelativeLayout>



            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="📍Toate Locațiile"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_toate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="80dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

        </LinearLayout>
    </RelativeLayout>
</androidx.core.widget.NestedScrollView>