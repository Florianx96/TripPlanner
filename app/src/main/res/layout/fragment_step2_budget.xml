<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Care este bugetul tău?" android:textSize="22sp"
            android:textStyle="bold" android:textColor="#1A1A2E" android:layout_marginBottom="6dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Per persoană, pe toată durata vacanței"
            android:textSize="14sp" android:textColor="#888888" android:layout_marginBottom="24dp" />

        <!-- Economic -->
        <LinearLayout android:id="@+id/option_economic"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="@drawable/bg_option_normal"
            android:padding="16dp" android:layout_marginBottom="12dp" android:gravity="center_vertical">

            <TextView android:layout_width="44dp" android:layout_height="44dp"
                android:text="💚" android:textSize="26sp" android:gravity="center" />
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Economic" android:textSize="16sp" android:textStyle="bold" android:textColor="#1A1A2E" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Sub 500 RON/zi — pensiuni, prețuri accesibile" android:textSize="13sp" android:textColor="#777777" />
            </LinearLayout>
        </LinearLayout>

        <!-- Mediu -->
        <LinearLayout android:id="@+id/option_mediu"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="@drawable/bg_option_normal"
            android:padding="16dp" android:layout_marginBottom="12dp" android:gravity="center_vertical">

            <TextView android:layout_width="44dp" android:layout_height="44dp"
                android:text="💛" android:textSize="26sp" android:gravity="center" />
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Mediu" android:textSize="16sp" android:textStyle="bold" android:textColor="#1A1A2E" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="500–1200 RON/zi — hoteluri 3★, experiențe bune" android:textSize="13sp" android:textColor="#777777" />
            </LinearLayout>
        </LinearLayout>

        <!-- Premium -->
        <LinearLayout android:id="@+id/option_premium"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="@drawable/bg_option_normal"
            android:padding="16dp" android:layout_marginBottom="12dp" android:gravity="center_vertical">

            <TextView android:layout_width="44dp" android:layout_height="44dp"
                android:text="💎" android:textSize="26sp" android:gravity="center" />
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Premium / Lux" android:textSize="16sp" android:textStyle="bold" android:textColor="#1A1A2E" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Peste 1200 RON/zi — hoteluri 4-5★, experiențe exclusive" android:textSize="13sp" android:textColor="#777777" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>