<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ce tip de vacanță dorești?"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alege tipul care ți se potrivește cel mai bine"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="24dp" />

        <!-- Munte -->
        <LinearLayout
            android:id="@+id/option_munte"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_option_normal"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <TextView android:layout_width="44dp" android:layout_height="44dp"
                android:text="⛰️" android:textSize="26sp" android:gravity="center" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Munte" android:textSize="16sp" android:textStyle="bold" android:textColor="#1A1A2E" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Peisaje montane, aer curat, trasee" android:textSize="13sp" android:textColor="#777777" />
            </LinearLayout>
        </LinearLayout>

        <!-- Mare -->
        <LinearLayout
            android:id="@+id/option_mare"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_option_normal"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <TextView android:layout_width="44dp" android:layout_height="44dp"
                android:text="🏖️" android:textSize="26sp" android:gravity="center" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Mare / Deltă" android:textSize="16sp" android:textStyle="bold" android:textColor="#1A1A2E" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Plaje, relaxare, natură acvatică" android:textSize="13sp" android:textColor="#777777" />
            </LinearLayout>
        </LinearLayout>

        <!-- City Break -->
        <LinearLayout
            android:id="@+id/option_city"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_option_normal"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <TextView android:layout_width="44dp" android:layout_height="44dp"
                android:text="🏙️" android:textSize="26sp" android:gravity="center" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="City Break" android:textSize="16sp" android:textStyle="bold" android:textColor="#1A1A2E" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Orașe, muzee, restaurant, cultură" android:textSize="13sp" android:textColor="#777777" />
            </LinearLayout>
        </LinearLayout>

        <!-- Aventura -->
        <LinearLayout
            android:id="@+id/option_aventura"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_option_normal"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <TextView android:layout_width="44dp" android:layout_height="44dp"
                android:text="🧗" android:textSize="26sp" android:gravity="center" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Aventură" android:textSize="16sp" android:textStyle="bold" android:textColor="#1A1A2E" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Drumeții, parcuri tematice, adrenalină" android:textSize="13sp" android:textColor="#777777" />
            </LinearLayout>
        </LinearLayout>

        <!-- Cultural -->
        <LinearLayout
            android:id="@+id/option_cultural"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_option_normal"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <TextView android:layout_width="44dp" android:layout_height="44dp"
                android:text="🏰" android:textSize="26sp" android:gravity="center" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Cultural / Istoric" android:textSize="16sp" android:textStyle="bold" android:textColor="#1A1A2E" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Cetăți, mănăstiri, monumente istorice" android:textSize="13sp" android:textColor="#777777" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>