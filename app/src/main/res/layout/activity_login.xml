<RelativeLayout
xmlns:android="http://schemas.android.com/apk/res/android"
android:layout_width="match_parent"
android:layout_height="match_parent"
android:background="@drawable/background_japan">

<LinearLayout
    android:orientation="vertical"
    android:padding="20dp"
    android:elevation="8dp"
    android:layout_marginVertical="150dp"
    android:layout_marginHorizontal="30dp"
    android:gravity="center"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_box">

    <TextView
        android:text="Log In"
        android:layout_marginBottom="30dp"
        android:gravity="center"
        android:textSize="30dp"
        android:textStyle="bold"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/editEmail"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:layout_marginBottom="10dp"
        android:textColorHint="#555555"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#000000"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <EditText
            android:id="@+id/editPassword"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:hint="Parola"
            android:inputType="textPassword"
            android:paddingEnd="8dp"
            android:textColorHint="#555555"
            android:backgroundTint="#000000"/>

        <ImageView
            android:id="@+id/ivTogglePassword"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="Toggle password"
            android:padding="8dp"
            android:src="@drawable/ic_eye_off"/>
    </LinearLayout>
    <CheckBox
        android:id="@+id/checkRemember"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ține-mă minte" />


    <Button
        android:id="@+id/btnLogin"
        android:backgroundTint="#2a6f82"
        android:text="Autentificare"
        android:layout_marginBottom="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/btnGoToRegister"
        android:backgroundTint="#729fab"
        android:text="Nu ai cont? Creeaza unul"
        android:layout_marginBottom="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <LinearLayout
        android:id="@+id/btnGoogleSignIn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/google_white_bg"
        android:gravity="center_vertical"
        android:padding="10dp"
        android:orientation="horizontal">

        <ImageView
            android:layout_marginLeft="50dp"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_google_logo" />

        <TextView
            android:layout_marginStart="12dp"
            android:text="Sign in with Google"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="16sp"

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>




</LinearLayout>
</RelativeLayout>