<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_japan">

<LinearLayout

    android:orientation="vertical"
    android:padding="20dp"
    android:elevation="8dp"
    android:layout_marginHorizontal="30dp"
    android:layout_marginVertical="130dp"
    android:gravity="center"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/login_box">

    <TextView
        android:text="Sign Up"
        android:layout_marginBottom="30dp"
        android:gravity="center"
        android:textSize="30dp"
        android:textStyle="bold"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <EditText
        android:id="@+id/editName"
        android:hint="Nume Utilizator"
        android:inputType="textPersonName"
        android:layout_marginBottom="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColorHint="#555555"
        android:backgroundTint="#000000"/>
    <EditText
        android:id="@+id/editEmail"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:layout_marginBottom="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColorHint="#555555"
        android:backgroundTint="#000000"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <EditText
            android:id="@+id/editPassword"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:hint="Parola"
            android:inputType="textPassword"
            android:paddingEnd="8dp"
            android:textColorHint="#555555"
            android:backgroundTint="#000000"/>

        <ImageView
            android:id="@+id/ivTogglePassword"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="Toggle password"
            android:padding="8dp"
            android:src="@drawable/ic_eye_off"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <EditText
            android:id="@+id/editConfirmPassword"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:hint="Confirmă parola"
            android:inputType="textPassword"
            android:paddingEnd="8dp"
            android:textColorHint="#555555"
            android:backgroundTint="#000000"/>

        <ImageView
            android:id="@+id/ivToggleConfirmPassword"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="Toggle confirm password"
            android:padding="8dp"
            android:src="@drawable/ic_eye_off"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnRegister"
        android:text="Creează cont"
        android:layout_marginBottom="10dp"
        android:backgroundTint="#2a6f82"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:id="@+id/btnGoToLogin"
        android:text="Ai deja cont? Autentifică-te"
        android:backgroundTint="#729fab"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

</LinearLayout>
</RelativeLayout>