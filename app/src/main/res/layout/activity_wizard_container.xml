<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Conținutul principal al wizard-ului -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@android:color/white">

        <!-- Header progres -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/tv_wizard_step"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pasul 1 din 5"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_marginBottom="8dp" />

            <ProgressBar
                android:id="@+id/progress_wizard"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:max="5"
                android:progress="1"
                android:progressTint="#4A90E2"
                android:progressBackgroundTint="#E8EEF7" />
        </LinearLayout>

        <!-- Container fragmente -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/wizard_fragment_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Butoane navigare -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="24dp">

            <Button
                android:id="@+id/btn_wizard_back"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="← Înapoi"
                android:textColor="#4A90E2"
                android:layout_marginEnd="12dp"
                android:visibility="invisible" />

            <Button
                android:id="@+id/btn_wizard_next"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Următorul →"
                android:backgroundTint="#4A90E2"
                android:textColor="@android:color/white" />
        </LinearLayout>
    </LinearLayout>

    <!-- Loading Overlay — apare peste tot când AI-ul generează -->
    <LinearLayout
        android:id="@+id/loading_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#EEFFFFFF"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:indeterminateTint="#4A90E2" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤖 AI-ul generează planul tău..."
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginTop="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Căutăm locații, prețuri și hoteluri..."
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Poate dura 15-30 secunde"
            android:textSize="12sp"
            android:textColor="#AAAAAA"
            android:layout_marginTop="4dp" />
    </LinearLayout>

</FrameLayout>