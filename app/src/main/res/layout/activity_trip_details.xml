<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fitsSystemWindows="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">
        <ImageButton
            android:id="@+id/btn_back_trip"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/bg_circle_translucent"
            app:tint="@android:color/white"
            android:layout_alignParentStart="true"/>

        <TextView
            android:id="@+id/tv_trip_detail_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/btn_back_trip"
            android:layout_marginStart="16dp"
            android:text="Nume Plan"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_centerVertical="true"
            android:layout_alignTop="@id/btn_back_trip"
            android:layout_alignBottom="@id/btn_back_trip"
            android:gravity="center_vertical"/>
        <Button
            android:id="@+id/btn_auto_sort"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Auto"
            android:textColor="@color/white"
            android:backgroundTint="#00ADC7"
            android:layout_alignParentTop="true"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:textAllCaps="false"
            app:cornerRadius="20dp" />


        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_below="@id/btn_back_trip"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_start_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/divider"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#E8F4F8">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@android:drawable/ic_menu_mylocation"
                    app:tint="#00ADC7" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Punct de plecare"
                        android:textSize="12sp"
                        android:textColor="#555555" />

                    <TextView
                        android:id="@+id/tv_start_location_address"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Punct de plecare nestabilit"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#000000" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_get_my_location"
                    android:layout_width="wrap_content"
                    android:layout_height="35dp"
                    android:text="Modifică"
                    android:textSize="10sp"
                    android:backgroundTint="#00ADC7"
                    android:textColor="@android:color/white" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_trip_locations"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/card_start_location"
            android:layout_above="@id/btn_view_map"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tv_empty_trip_locations"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Nu ai nicio locație în acest plan."
            android:textSize="16sp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btn_view_map"
            android:layout_centerHorizontal="true"
            android:layout_width="wrap_content"
            android:layout_height="55dp"
            android:layout_marginBottom="20dp"
            android:layout_alignParentBottom="true"
            android:text="🗺️ Vezi Traseul pe Hartă"
            android:backgroundTint="#00ADC7"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="8dp"/>
    </RelativeLayout>
</RelativeLayout>