<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ImageButton
        android:id="@+id/btn_back_from_map"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:src="@drawable/ic_back"
        android:background="@drawable/bg_circle_translucent"
        android:elevation="4dp"
        app:tint="@android:color/white" />

    <androidx.cardview.widget.CardView
        android:id="@+id/card_route_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        android:visibility="gone"> <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#E8F4F8"
        android:gravity="center">

        <TextView
            android:id="@+id/tv_route_distance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-- km"
            android:textStyle="bold"
            android:textColor="#00ADC7"
            android:textSize="16sp"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/tv_route_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-- min"
            android:textStyle="bold"
            android:textColor="#555555"
            android:textSize="16sp"/>
    </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="24dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/btn_fuel_calculator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cost"
            app:icon="@android:drawable/ic_menu_sort_by_size"
            android:textColor="#333333"
            android:backgroundTint="@android:color/white"
            android:elevation="6dp"
            android:layout_marginEnd="16dp"
            android:visibility="gone"/>

        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/btn_start_navigation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Navighează"
            app:icon="@android:drawable/ic_dialog_map"
            android:textColor="@android:color/white"
            android:backgroundTint="#00ADC7"
            android:elevation="6dp"/>
    </LinearLayout>

</RelativeLayout>