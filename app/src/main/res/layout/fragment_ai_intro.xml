<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingTop="36dp"
        >

        <!-- Iconița mare AI -->
        <ImageView
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_ai_spark"
            android:background="@drawable/bg_ai_icon_circle"
            android:padding="10dp"
            android:layout_marginBottom="32dp" />

        <!-- Titlu principal -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Planifică-ți vacanța"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <!-- Subtitlu -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="cu ajutorul Inteligenței Artificiale"
            android:textSize="20sp"
            android:textColor="#4A90E2"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Descriere -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Răspunde la câteva întrebări simple și AI-ul nostru va crea pentru tine un itinerariu personalizat bazat pe locațiile din România, cu prețuri reale și recomandări de cazare."
            android:textSize="16sp"
            android:textColor="#555555"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="40dp" />

        <!-- Card Feature 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_feature_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="📍"
                android:textSize="22sp"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Locații reale din România"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Planul se bazează pe locațiile din baza noastră de date"
                    android:textSize="13sp"
                    android:textColor="#777777" />
            </LinearLayout>
        </LinearLayout>

        <!-- Card Feature 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_feature_card"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="💰"
                android:textSize="22sp"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Prețuri actuale"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI-ul caută online prețuri reale de intrare și hoteluri"
                    android:textSize="13sp"
                    android:textColor="#777777" />
            </LinearLayout>
        </LinearLayout>

        <!-- Card Feature 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_feature_card"
            android:padding="16dp"
            android:layout_marginBottom="48dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="🗓️"
                android:textSize="22sp"
                android:gravity="center" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Plan pe zile"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Itinerariu detaliat organizat pe fiecare zi"
                    android:textSize="13sp"
                    android:textColor="#777777" />
            </LinearLayout>
        </LinearLayout>

        <!-- Butonul principal -->
        <Button
            android:id="@+id/btn_get_started"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Creează Planul Meu"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:backgroundTint="#4A90E2"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

    </LinearLayout>
</ScrollView>